# Copia este archivo a ".env" y completa los valores. NUNCA subas ".env" al repo.

# --- Proveedor de LLM (intercambiable) ---
LLM_PROVIDER=gemini            # gemini | openai | local
GOOGLE_API_KEY=tu_api_key_de_google_ai_studio
# OPENAI_API_KEY=             # solo si usas openai

# Modelos (valores por defecto razonables; ajustables)
LLM_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=gemini-embedding-001

# --- Base de datos vectorial (coincide con docker-compose.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gobernanza
DB_USER=postgres
DB_PASSWORD=postgres
# DB_SSLMODE=require          # requerido por Postgres gestionados en la nube; vacío en local

# --- Backend del vector store del RAG (enchufable) ---
RAG_BACKEND=postgres          # postgres (local, pgVector) | bigquery (nube / GCP)
# Si RAG_BACKEND=bigquery (autenticación por ADC o service account, sin contraseña):
# BQ_PROJECT=tu-proyecto-gcp
# BQ_DATASET=gobernanza
# BQ_LOCATION=US

# --- Protección de la API pública (endpoint /ask) ---
RATE_LIMIT_PER_MIN=6          # máx preguntas por IP por minuto
DAILY_ASK_CAP=100             # tope global de preguntas por día

# --- UI Streamlit ---
# API_URL=http://localhost:8000   # URL de la API que consume la UI
